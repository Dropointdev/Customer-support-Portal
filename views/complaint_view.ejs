<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Ticket <%= complaint.helpId %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --sidebar-width: 260px;
      --topbar-height: 70px;
      --bg-light: #f8fafc;
      --primary-accent: #4f46e5;
    }

    body {
      font-family: "Plus Jakarta Sans", sans-serif;
      background-color: var(--bg-light);
      color: #1e293b;
    }

    /* Sidebar */
    .sidebar {
      width: var(--sidebar-width);
      height: 100vh;
      position: fixed;
      left: 0;
      top: 0;
      background: white;
      border-right: 1px solid #e2e8f0;
      z-index: 1000;
      padding: 1.5rem;
    }

    .nav-link {
      color: #64748b;
      font-weight: 500;
      padding: 12px 15px;
      border-radius: 10px;
      margin-bottom: 5px;
      transition: all 0.2s;
    }

    .nav-link:hover, .nav-link.active {
      background: #f1f5f9;
      color: var(--primary-accent);
    }

    /* Topbar */
    .topbar {
      height: var(--topbar-height);
      position: fixed;
      top: 0;
      right: 0;
      left: var(--sidebar-width);
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid #e2e8f0;
      z-index: 999;
      display: flex;
      align-items: center;
      padding: 0 2rem;
    }

    /* Main Content */
    .main-content {
      margin-left: var(--sidebar-width);
      padding-top: calc(var(--topbar-height) + 2rem);
      padding-left: 2rem;
      padding-right: 2rem;
      padding-bottom: 3rem;
    }

    .card {
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    /* Video Terminal Styling */
    .video-container {
      background: #0f172a;
      border-radius: 12px;
      overflow: hidden;
      aspect-ratio: 16/9;
      position: relative;
    }

    /* Badge & Status Pills */
    .badge-pill {
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .badge-high { background: #fff1f2; color: #e11d48; border: 1px solid #fecdd3; }
    .badge-open { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
    .badge-resolved { background: #ecfdf5; color: #059669; border: 1px solid #a7f3d0; }

    .action-btn {
      border-radius: 10px;
      font-weight: 600;
      padding: 10px;
      font-size: 14px;
      transition: transform 0.1s;
    }

    .action-btn:active { transform: scale(0.98); }

    .timeline-item {
      padding-left: 20px;
      border-left: 2px solid #e2e8f0;
      position: relative;
      padding-bottom: 20px;
    }

    .timeline-item::after {
      content: '';
      position: absolute;
      left: -7px;
      top: 0;
      width: 12px;
      height: 12px;
      background: var(--primary-accent);
      border-radius: 50%;
    }
  </style>
</head>
<body>

  <aside class="sidebar">
    <div class="d-flex align-items-center mb-5 px-2">
      <div class="bg-primary text-white rounded-3 p-2 me-2">
        <i class="fa-solid fa-screwdriver-wrench"></i>
      </div>
      <h5 class="mb-0 fw-bold">Droppoint Support </h5>
    </div>

    <nav class="nav flex-column">
    
      <a class="nav-link active" href="/"><i class="fa-solid fa-ticket me-2"></i> Complaints</a>
      
    </nav>
  </aside>

  <header class="topbar justify-content-between">
    <div class="fw-medium text-secondary">
      <a href="/" class="text-decoration-none text-secondary">Complaints</a> 
      <span class="mx-2">/</span> 
      <span class="text-dark">Ticket Detail</span>
    </div>
    <div class="d-flex align-items-center">
      <img src="https://ui-avatars.com/api/?name=User&background=4f46e5&color=fff" class="rounded-circle" width="35">
    </div>
  </header>

  <main class="main-content">
    <div class="container-fluid">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <a href="/" class="text-primary text-decoration-none small fw-bold mb-2 d-inline-block">
            <i class="fa fa-arrow-left me-1"></i> Back to Queue
          </a>
          <h2 class="fw-bold mb-1"><%= complaint.helpId %></h2>
          <p class="text-secondary small mb-0">Opened on <%= complaint.createdAt.toLocaleString() %></p>
        </div>
        <div class="d-flex gap-2">
          <span class="badge-pill badge-high">PRIORITY: HIGH</span>
          <span class="badge-pill badge-open"><%= complaint.status.toUpperCase() %></span>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-lg-8">
          
          <div class="card border-0 mb-4 overflow-hidden">
            <div class="card-header bg-white border-bottom-0 pt-3 px-4 d-flex justify-content-between align-items-center">
              <span class="fw-bold"><i class="fa fa-video me-2 text-danger"></i>Live Terminal Feed</span>
              <span class="badge rounded-pill bg-danger">LIVE</span>
            </div>
            <div class="p-3">
              <div class="video-container">
                <video width="100%" height="100%" controls class="d-block">
                  <source src="/placeholder-cctv.mp4" type="video/mp4">
                </video>
              </div>
              <div class="d-flex justify-content-center gap-3 mt-3">
                <button class="btn btn-sm btn-light border rounded-circle"><i class="fa fa-rotate"></i></button>
                <button class="btn btn-sm btn-light border rounded-circle"><i class="fa fa-volume-high"></i></button>
                <button class="btn btn-sm btn-light border rounded-circle"><i class="fa fa-expand"></i></button>
              </div>
            </div>
          </div>

          <div class="card border-0 mb-4">
            <div class="card-body p-4">
              <h6 class="fw-bold mb-3">⚡ Quick Actions</h6>
              <div class="row g-3">
                <div class="col-md-6">
                  <button class="btn btn-success w-100 action-btn"><i class="fa fa-unlock me-2"></i>Unlock Compartment</button>
                </div>
                <div class="col-md-6">
                  <button class="btn btn-outline-danger w-100 action-btn"><i class="fa fa-triangle-exclamation me-2"></i>Escalate Issue</button>
                </div>
                <div class="col-md-6">
                  <button class="btn btn-outline-secondary w-100 action-btn"><i class="fa fa-phone me-2"></i>Call Customer</button>
                </div>
                <div class="col-md-6">
                  <form method="POST" action="/complaints/<%= complaint._id %>/status">
                    <input type="hidden" name="status" value="resolved">
                    <button class="btn btn-primary w-100 action-btn"><i class="fa fa-check-circle me-2"></i>Mark Resolved</button>
                  </form>
                </div>
              </div>
            </div>
          </div>

          <div class="card border-0">
            <div class="card-body p-4">
              <h6 class="fw-bold mb-4">🕒 Issue Timeline</h6>
              <div class="timeline-item">
                <div class="fw-bold small">Ticket Created</div>
                <div class="text-secondary smaller"><%= complaint.createdAt.toLocaleString() %></div>
              </div>
              <% if (complaint.status !== "open") { %>
              <div class="timeline-item border-0">
                <div class="fw-bold small">Status Updated to <%= complaint.status %></div>
                <div class="text-secondary smaller"><%= complaint.updatedAt.toLocaleString() %></div>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          
          <div class="card border-0 mb-4">
            <div class="card-body p-4">
              <h6 class="fw-bold mb-3"><i class="fa fa-user me-2 text-primary"></i>Customer</h6>
              <div class="text-secondary small mb-1">User ID</div>
              <div class="fw-bold mb-3"><%= complaint.userId || "Unknown User" %></div>
              <button class="btn btn-outline-primary btn-sm w-100 rounded-pill">💬 Send SMS</button>
            </div>
          </div>

          <div class="card border-0 mb-4">
            <div class="card-body p-4">
              <h6 class="fw-bold mb-3"><i class="fa fa-box me-2 text-primary"></i>Terminal Details</h6>
              <div class="mb-3">
                <div class="text-secondary small">Terminal ID</div>
                <div class="fw-bold text-primary"><%= complaint.lockerId %></div>
              </div>
              <div class="mb-3">
                <div class="text-secondary small">Compartment</div>
                <div class="fw-bold"><%= complaint.compartmentId || "N/A" %></div>
              </div>
              <div>
                <div class="text-secondary small">Issue Type</div>
                <div class="fw-bold"><%= complaint.category.replace(/_/g," ") %></div>
              </div>
            </div>
          </div>

          <div class="card border-0">
            <div class="card-body p-4">
              <h6 class="fw-bold mb-3"><i class="fa fa-pen me-2 text-primary"></i>Internal Notes</h6>
              <textarea class="form-control bg-light border-0 mb-3" rows="4" placeholder="Type internal update..." style="resize: none; font-size: 14px;"></textarea>
              <button class="btn btn-primary w-100 action-btn">Save Notes</button>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

</body>
</html>