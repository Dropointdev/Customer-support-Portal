<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Session <%= sessionId %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root { --sidebar-width: 260px; --topbar-height: 70px; --bg-light: #f8fafc; --primary-accent: #4f46e5; }
    body { font-family: "Plus Jakarta Sans", sans-serif; background-color: var(--bg-light); color: #1e293b; }
    .sidebar { width: var(--sidebar-width); height: 100vh; position: fixed; left: 0; top: 0; background: white; border-right: 1px solid #e2e8f0; z-index: 1000; padding: 1.5rem; }
    .nav-link { color: #64748b; font-weight: 500; padding: 12px 15px; border-radius: 10px; margin-bottom: 5px; transition: all 0.2s; }
    .nav-link:hover { background: #f1f5f9; color: var(--primary-accent); }
    .topbar { height: var(--topbar-height); position: fixed; top: 0; right: 0; left: var(--sidebar-width); background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); border-bottom: 1px solid #e2e8f0; z-index: 999; display: flex; align-items: center; padding: 0 2rem; }
    .main-content { margin-left: var(--sidebar-width); padding-top: calc(var(--topbar-height) + 2rem); padding-left: 2rem; padding-right: 2rem; padding-bottom: 3rem; }
    .card { background: white; border: 1px solid #e2e8f0; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
    .video-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 14px; }
    .video-card { border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; background: white; }
    .video-card-header { display: flex; justify-content: space-between; align-items: center; padding: 8px 12px; background: #f8fafc; border-bottom: 1px solid #f0f0f0; }
    .cam-label { font-size: 11px; font-weight: 700; color: #374151; letter-spacing: 1px; text-transform: uppercase; }
    .video-ts { font-size: 10px; color: #9ca3af; }
    .video-wrap { position: relative; padding-top: 56.25%; background: #0f172a; }
    .video-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
    .video-placeholder { aspect-ratio: 16/9; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; background: #0f172a; }
    .video-open-link { display: block; text-align: right; padding: 6px 12px; font-size: 11px; color: #4f46e5; text-decoration: none; border-top: 1px solid #f0f0f0; font-weight: 500; }
    .video-open-link:hover { background: #f8fafc; }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="d-flex align-items-center mb-5 px-2">
    <div class="bg-primary text-white rounded-3 p-2 me-2">
      <i class="fa-solid fa-screwdriver-wrench"></i>
    </div>
    <h5 class="mb-0 fw-bold">Droppoint Support</h5>
  </div>
  <nav class="nav flex-column">
    <a class="nav-link" href="/"><i class="fa-solid fa-video me-2"></i> Transactions</a>
  </nav>
</aside>

<header class="topbar justify-content-between">
  <div class="fw-medium text-secondary">
    <a href="/" class="text-decoration-none text-secondary">Transactions</a>
    <span class="mx-2">/</span>
    <span class="text-dark"><%= sessionId %></span>
  </div>
</header>

<main class="main-content">
  <div class="container-fluid">

    <div class="mb-4">
      <a href="/" class="text-primary text-decoration-none small fw-bold mb-2 d-inline-block">
        <i class="fa fa-arrow-left me-1"></i> Back to Transactions
      </a>
      <h2 class="fw-bold mb-1"><%= sessionId %></h2>
      <p class="text-secondary small mb-0">
        Locker: <strong><%= lockerId %></strong>
        &nbsp;•&nbsp;
        Started: <strong><%= startedAt ? new Date(startedAt).toLocaleString() : "—" %></strong>
      </p>
    </div>

    <!-- Videos -->
    <div class="card border-0 mb-4">
      <div class="card-header bg-white border-bottom pt-3 px-4 d-flex justify-content-between align-items-center">
        <span class="fw-bold">
          <i class="fa fa-video me-2 text-danger"></i>Transaction Recordings
        </span>
        <span id="video-badge" class="badge rounded-pill bg-secondary">
          ⏳ Loading...
        </span>
      </div>
      <div class="p-3">
        <div id="video-grid" class="video-grid">
          <div class="video-placeholder" style="border-radius:10px">
            <i class="fa fa-video text-secondary" style="font-size:22px;opacity:.3"></i>
            <span class="text-secondary small">Loading recordings...</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Session details -->
    <div class="card border-0">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-3"><i class="fa fa-circle-info me-2 text-primary"></i>Session Details</h6>
        <div class="row g-3">
          <% sessions.forEach(s => { %>
          <div class="col-md-6">
            <div class="p-3 bg-light rounded-3">
              <div class="text-secondary small mb-1">Camera</div>
              <div class="fw-bold"><%= s.cameraId %></div>
              <div class="text-secondary small mt-2 mb-1">Status</div>
              <div class="fw-bold"><%= s.status %></div>
              <% if (s.uploadedAt) { %>
              <div class="text-secondary small mt-2 mb-1">Uploaded</div>
              <div class="fw-bold small"><%= new Date(s.uploadedAt).toLocaleString() %></div>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const SESSION_ID = "<%= sessionId %>";
  const grid  = document.getElementById("video-grid");
  const badge = document.getElementById("video-badge");

  function renderCard(video) {
    const ts = video.uploadedAt ? new Date(video.uploadedAt).toLocaleString() : "";

    if (video.status === "ready" && video.embedUrl) {
      return `
        <div class="video-card">
          <div class="video-card-header">
            <span class="cam-label">📷 ${video.cameraId}</span>
            <span class="video-ts">${ts}</span>
          </div>
          <div class="video-wrap">
            <iframe src="${video.embedUrl}" allow="autoplay" allowfullscreen loading="lazy"></iframe>
          </div>
          <a href="${video.viewUrl}" target="_blank" class="video-open-link">↗ Open in Drive</a>
        </div>`;
    }

    return `
      <div class="video-card">
        <div class="video-card-header">
          <span class="cam-label">📷 ${video.cameraId}</span>
        </div>
        <div class="video-placeholder">
          <i class="fa fa-spinner fa-spin text-secondary" style="font-size:20px;opacity:.5"></i>
          <span class="text-secondary small mt-1">
            ${video.status === "processing" ? "Processing..." : "Awaiting upload..."}
          </span>
        </div>
      </div>`;
  }

  async function fetchVideos() {
    try {
      const res  = await fetch(`/api/videos/${SESSION_ID}`);
      const data = await res.json();

      if (!data.success || !data.videos?.length) {
        grid.innerHTML = `
          <div class="video-placeholder" style="border-radius:10px;grid-column:1/-1">
            <i class="fa fa-video-slash text-secondary" style="font-size:22px;opacity:.4"></i>
            <span class="text-secondary small mt-1">No recordings found for this session.</span>
          </div>`;
        badge.textContent = "No recordings";
        badge.className   = "badge rounded-pill bg-secondary";
        return true;
      }

      const readyCount = data.videos.filter(v => v.status === "ready").length;
      const allReady   = readyCount === data.videos.length;

      badge.textContent = allReady
        ? `✅ ${readyCount} video${readyCount > 1 ? "s" : ""} ready`
        : `⏳ ${readyCount} / ${data.videos.length} ready`;
      badge.className = `badge rounded-pill ${allReady ? "bg-success" : "bg-secondary"}`;

      grid.innerHTML = data.videos.map(renderCard).join("");
      return allReady;

    } catch (err) {
      badge.textContent = "Error loading";
      badge.className   = "badge rounded-pill bg-danger";
      return true;
    }
  }

  fetchVideos().then(allReady => {
    if (!allReady) {
      const poll = setInterval(async () => {
        if (await fetchVideos()) clearInterval(poll);
      }, 10000);
    }
  });
</script>
</body>
</html>
