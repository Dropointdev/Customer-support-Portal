<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Support Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root { --sidebar-width: 260px; --topbar-height: 70px; --bg-light: #f8fafc; --primary-accent: #4f46e5; }
    body { font-family: "Plus Jakarta Sans", sans-serif; background-color: var(--bg-light); color: #1e293b; overflow-x: hidden; }
    .sidebar { width: var(--sidebar-width); height: 100vh; position: fixed; left: 0; top: 0; background: white; border-right: 1px solid #e2e8f0; z-index: 1000; padding: 1.5rem; }
    .nav-link { color: #64748b; font-weight: 500; padding: 12px 15px; border-radius: 10px; margin-bottom: 5px; transition: all 0.2s; }
    .nav-link:hover, .nav-link.active { background: #f1f5f9; color: var(--primary-accent); }
    .topbar { height: var(--topbar-height); position: fixed; top: 0; right: 0; left: var(--sidebar-width); background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); border-bottom: 1px solid #e2e8f0; z-index: 999; display: flex; align-items: center; padding: 0 2rem; }
    .main-content { margin-left: var(--sidebar-width); padding-top: calc(var(--topbar-height) + 2rem); padding-left: 2rem; padding-right: 2rem; min-height: 100vh; }
    .card { background: white; border: 1px solid #e2e8f0; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
    .table thead th { background: #f8fafc; color: #64748b; text-transform: uppercase; font-size: 11px; letter-spacing: 0.05em; padding: 15px; }
    .table tbody tr:hover { background: #fafbfc; }
    .status-pill { padding: 4px 12px; border-radius: 8px; font-size: 12px; font-weight: 600; display: inline-block; text-transform: capitalize; }
    .status-active    { background: #eff6ff; color: #1d4ed8; }
    .status-completed { background: #ecfdf5; color: #059669; }
    .status-recording { background: #fff7ed; color: #c2410c; }
    .btn-primary { background: var(--primary-accent); border: none; border-radius: 10px; font-weight: 600; }
    .btn-primary:hover { background: #4338ca; }
    .btn-video { font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 20px; border: 1px solid #c7d2fe; background: #eef2ff; color: #4f46e5; text-decoration: none; display: inline-flex; align-items: center; gap: 5px; transition: all 0.15s; }
    .btn-video:hover { background: #4f46e5; color: white; border-color: #4f46e5; }
    .btn-video.pending { background: #f8fafc; color: #94a3b8; border-color: #e2e8f0; pointer-events: none; }
    .search-bar { background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 1rem 1.5rem; margin-bottom: 1.5rem; }
    #userMenu { padding: 5px 10px; border-radius: 50px; transition: background 0.2s; }
    #userMenu:hover { background: #f1f5f9; }
    .dropdown-item { transition: all 0.2s; border-radius: 6px; margin: 0 8px; width: calc(100% - 16px); }
    .dropdown-item:hover { background-color: #f1f5f9; color: var(--primary-accent); }
    .dropdown-item.text-danger:hover { background-color: #fff1f2; color: #e11d48; }
  </style>
</head>
<body>

<aside class="sidebar">
  <div class="d-flex align-items-center mb-5 px-2">
    <div class="bg-primary text-white rounded-3 p-2 me-2">
      <i class="fa-solid fa-screwdriver-wrench"></i>
    </div>
    <h5 class="mb-0 fw-bold">Droppoint Support</h5>
  </div>
  <nav class="nav flex-column">
    <a class="nav-link active" href="/"><i class="fa-solid fa-video me-2"></i> Transactions</a>
  </nav>
</aside>

<header class="topbar justify-content-between">
  <div class="fw-medium text-secondary">
    <span class="text-dark">Transaction Recordings</span>
  </div>
  <div class="d-flex align-items-center">
    <div class="dropdown">
      <div class="d-flex align-items-center gap-2" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer">
        <div class="text-end d-none d-md-block me-2">
          <div class="fw-bold small text-dark" style="line-height:1"><%= agent.name %></div>
          <div class="text-secondary" style="font-size:11px"><%= agent.role.toUpperCase() %></div>
        </div>
        <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(agent.name) %>&background=4f46e5&color=fff" class="rounded-circle border" width="38"/>
      </div>
      <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3" style="border-radius:12px;min-width:200px">
        <li class="px-3 py-2 border-bottom mb-1">
          <div class="small text-muted">Signed in as</div>
          <div class="fw-bold small"><%= agent.email %></div>
        </li>
        <li><hr class="dropdown-divider opacity-50"></li>
        <li><a class="dropdown-item py-2 small text-danger fw-bold" href="/logout"><i class="fa fa-sign-out-alt me-2"></i>Sign Out</a></li>
      </ul>
    </div>
  </div>
</header>

<main class="main-content">
  <div class="container-fluid">

    <div class="mb-4">
      <h2 class="fw-bold mb-1">🎥 Transaction Recordings</h2>
      <p class="text-secondary mb-0">Browse and review locker transaction videos</p>
    </div>

    <!-- Search bar -->
    <div class="search-bar">
      <form method="GET" action="/" class="row g-2 align-items-end">
        <div class="col-md-5">
          <label class="form-label small fw-semibold text-secondary mb-1">Search by Session ID or Camera</label>
          <input type="text" name="q" class="form-control" placeholder="e.g. HR-1775732675835" value="<%= typeof q !== 'undefined' ? q : '' %>"/>
        </div>
        <div class="col-md-4">
          <label class="form-label small fw-semibold text-secondary mb-1">Filter by Locker ID</label>
          <input type="text" name="lockerId" class="form-control" placeholder="e.g. L01" value="<%= typeof lockerId !== 'undefined' ? lockerId : '' %>"/>
        </div>
        <div class="col-md-3 d-flex gap-2">
          <button type="submit" class="btn btn-primary w-100">
            <i class="fa fa-search me-2"></i>Search
          </button>
          <a href="/" class="btn btn-outline-secondary">Clear</a>
        </div>
      </form>
    </div>

    <div class="card border-0">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th class="ps-4">Session ID</th>
              <th>Locker</th>
              <th>Camera</th>
              <th>Status</th>
              <th>Started</th>
              <th class="text-center">Video</th>
              <th class="text-end pe-4">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (sessions.length === 0) { %>
              <tr>
                <td colspan="7" class="text-center text-secondary py-5">
                  <i class="fa-regular fa-folder-open d-block fs-2 mb-2"></i>
                  No recordings found.
                </td>
              </tr>
            <% } %>

            <% sessions.forEach(s => { %>
              <tr>
                <td class="ps-4 fw-bold text-dark"><%= s.sessionId %></td>
                <td class="fw-semibold"><%= s.lockerId || "—" %></td>
                <td>
                  <span class="badge bg-light text-dark border fw-medium px-2 py-1">
                    <i class="fa fa-camera me-1"></i><%= s.cameraId || "—" %>
                  </span>
                </td>
                <td>
                  <span class="status-pill status-<%= s.status || 'unknown' %>">
                    <%= s.status || "unknown" %>
                  </span>
                </td>
                <td class="text-secondary small">
                  <%= s.startedAt ? new Date(s.startedAt).toLocaleString() : "—" %>
                </td>
                <td class="text-center">
                  <% if (s.embedUrl) { %>
                    <a href="/sessions/<%= s.sessionId %>" class="btn-video">
                      <i class="fa fa-video"></i> View
                    </a>
                  <% } else { %>
                    <span class="btn-video pending">
                      <i class="fa fa-clock"></i> Pending
                    </span>
                  <% } %>
                </td>
                <td class="text-end pe-4">
                  <a href="/sessions/<%= s.sessionId %>" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                    View
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
