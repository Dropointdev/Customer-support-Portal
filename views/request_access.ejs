<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Request Access | DropPoint</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --primary-accent: #4f46e5;
      --bg-light: #f8fafc;
    }

    body {
      min-height: 100vh;
      background-color: var(--bg-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: "Plus Jakarta Sans", sans-serif;
      padding: 20px;
    }

    /* Background pattern to match login */
    body::before {
      content: "";
      position: absolute;
      width: 100%;
      height: 100%;
      background-image: radial-gradient(#e2e8f0 1px, transparent 1px);
      background-size: 30px 30px;
      z-index: -1;
      opacity: 0.5;
    }

    .card {
      background: white;
      border-radius: 24px;
      padding: 40px;
      width: 100%;
      max-width: 500px;
      border: 1px solid #e2e8f0;
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .icon-header {
      width: 50px;
      height: 50px;
      background: #eef2ff;
      color: var(--primary-accent);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      margin-bottom: 20px;
    }

    .form-label {
      font-size: 14px;
      font-weight: 600;
      color: #475569;
      margin-bottom: 8px;
    }

    .form-control {
      border-radius: 12px;
      padding: 12px 16px;
      border: 1px solid #e2e8f0;
      background-color: #fcfcfd;
      font-size: 15px;
      transition: all 0.2s;
    }

    .form-control:focus {
      border-color: var(--primary-accent);
      box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
      background-color: #fff;
    }

    .btn-primary {
      background-color: var(--primary-accent);
      border: none;
      border-radius: 12px;
      padding: 14px;
      font-weight: 700;
      font-size: 15px;
      transition: all 0.2s;
    }

    .btn-primary:hover {
      background-color: #4338ca;
      transform: translateY(-1px);
    }

    /* Custom Alert Styling */
    .alert {
      border-radius: 12px;
      border: none;
      font-size: 14px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .alert-danger { background-color: #fff1f2; color: #e11d48; }
    .alert-success { background-color: #f0fdf4; color: #166534; }

    .back-link {
      color: #64748b;
      font-size: 14px;
      font-weight: 600;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: var(--primary-accent);
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="icon-header">
      <i class="fa-solid fa-user-plus"></i>
    </div>
    
    <h3 class="fw-bold text-dark mb-1">Request Access</h3>
    <p class="text-secondary mb-4 small">Submit your details to the administrator to gain support agent permissions.</p>

    <% if (error) { %>
      <div class="alert alert-danger shadow-sm mb-4">
        <i class="fa-solid fa-circle-exclamation"></i>
        <%= error %>
      </div>
    <% } %>

    <% if (success) { %>
      <div class="alert alert-success shadow-sm mb-4">
        <i class="fa-solid fa-circle-check"></i>
        Request submitted! We'll notify you via email.
      </div>
    <% } %>

    <form method="POST" action="/request-access">

      <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input name="name" class="form-control" placeholder="" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input name="email" type="email" class="form-control" placeholder="" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Phone Number</label>
        <input name="phone" class="form-control" placeholder="" />
      </div>

      <div class="mb-4">
        <label class="form-label">Reason for Access</label>
        <textarea name="reason" class="form-control" rows="3" placeholder="Briefly describe your role..." style="resize: none;"></textarea>
      </div>

      <button class="btn btn-primary w-100 shadow-sm mb-3">
        Submit Request
      </button>

      <div class="text-center">
        <a href="/login" class="back-link text-decoration-none">
          <i class="fa fa-arrow-left me-1"></i> Back to Login
        </a>
      </div>

    </form>
  </div>

</body>
</html>